import { WSMessage } from '../types';

type MessageHandler = (message: WSMessage) => void;
type ConnectionHandler = () => void;

class WebSocketService {
  private ws: WebSocket | null = null;
  private url: string;
  private token: string | null = null;
  private authenticated = false;
  private pendingAuth = false;
  private messageHandlers: Set<MessageHandler> = new Set();
  private openHandlers: Set<ConnectionHandler> = new Set();
  private closeHandlers: Set<ConnectionHandler> = new Set();
  private errorHandlers: Set<ConnectionHandler> = new Set();
  private reconnectAttempts = 0;
  private maxReconnectAttempts = 5;
  private reconnectDelay = 3000;
  private isManualClose = false;

  constructor(url: string = `ws://${window.location.hostname}:80`) {
    this.url = url;
  }

  setToken(token: string): void {
    this.token = token;
  }

  isAuthenticated(): boolean {
    return this.authenticated;
  }

  private buildUrl(): string {
    if (this.token) {
      const separator = this.url.includes('?') ? '&' : '?';
      return `${this.url}${separator}token=${encodeURIComponent(this.token)}`;
    }
    return this.url;
  }

  private sendAuthIfNeeded(): void {
    if (this.token && !this.authenticated) {
      this.pendingAuth = true;
      this.send({ type: 'auth', data: this.token });
    }
  }

  connect(): void {
    if (this.ws?.readyState === WebSocket.OPEN) {
      return;
    }

    this.isManualClose = false;
    this.authenticated = false;
    this.ws = new WebSocket(this.buildUrl());

    this.ws.onopen = () => {
      console.log('WebSocket connected');
      this.reconnectAttempts = 0;
      this.sendAuthIfNeeded();
      this.openHandlers.forEach((handler) => handler());
    };

    this.ws.onclose = () => {
      console.log('WebSocket closed');
      this.closeHandlers.forEach((handler) => handler());
      
      if (!this.isManualClose && this.reconnectAttempts < this.maxReconnectAttempts) {
        this.scheduleReconnect();
      }
    };

    this.ws.onerror = (error) => {
      console.error('WebSocket error:', error);
      this.errorHandlers.forEach((handler) => handler());
    };

    this.ws.onmessage = (event) => {
      try {
        const message: WSMessage = JSON.parse(event.data);
        // Handle auth_success message
        if (message.type === 'auth_success') {
          this.authenticated = true;
          this.pendingAuth = false;
          console.log('[WS] Authentication successful');
        }
        this.messageHandlers.forEach((handler) => handler(message));
      } catch (error) {
        console.error('Failed to parse WebSocket message:', error);
      }
    };
  }

  private scheduleReconnect(): void {
    this.reconnectAttempts++;
    console.log(`Reconnecting... Attempt ${this.reconnectAttempts}/${this.maxReconnectAttempts}`);
    setTimeout(() => this.connect(), this.reconnectDelay);
  }

  disconnect(): void {
    this.isManualClose = true;
    this.ws?.close();
    this.ws = null;
  }

  send(data: WSMessage): void {
    if (this.ws?.readyState === WebSocket.OPEN) {
      this.ws.send(JSON.stringify(data));
    } else {
      console.warn('WebSocket is not connected');
    }
  }

  onMessage(handler: MessageHandler): () => void {
    this.messageHandlers.add(handler);
    return () => this.messageHandlers.delete(handler);
  }

  onOpen(handler: ConnectionHandler): () => void {
    this.openHandlers.add(handler);
    return () => this.openHandlers.delete(handler);
  }

  onClose(handler: ConnectionHandler): () => void {
    this.closeHandlers.add(handler);
    return () => this.closeHandlers.delete(handler);
  }

  onError(handler: ConnectionHandler): () => void {
    this.errorHandlers.add(handler);
    return () => this.errorHandlers.delete(handler);
  }

  get isConnected(): boolean {
    return this.ws?.readyState === WebSocket.OPEN;
  }

  get hasPendingAuth(): boolean {
    return this.pendingAuth;
  }
}

export const wsService = new WebSocketService();
export default wsService;