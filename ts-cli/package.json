{
  "name": "@jwcode/cli",
  "version": "3.0.2",
  "description": "JWCode — Java AI Coding Tool TypeScript CLI",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "jwcode": "./dist/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun run build.mjs",
    "go": "bun run build.mjs && bun run dist/cli.js run",
    "start": "bun run build.mjs && bun run dist/cli.js start",
    "prepublishOnly": "bun run build.mjs --publish",
    "postinstall": "node scripts/download-jar.js && node scripts/download-jre.js",
    "build:jre": "node scripts/build-jre-zip.js",
    "publish:all": "node scripts/publish-all.mjs"
  },
  "dependencies": {
    "@opentui/core": "^0.4.0",
    "@opentui/solid": "^0.4.0",
    "@solid-primitives/i18n": "2.2.1",
    "marked": "^14.1.0",
    "solid-js": "^1.9.13",
    "ws": "^8.18.0"
  },
  "files": [
    "dist/",
    "backend/",
    "scripts/download-jar.js",
    "scripts/download-jre.js"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
