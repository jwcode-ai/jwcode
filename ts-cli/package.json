{
  "name": "@jwcode/cli",
  "version": "3.0.1",
  "description": "JWCode — Java AI Coding Tool TypeScript CLI",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "jwcode": "./dist/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node build.mjs",
    "go": "node build.mjs && node dist/cli.js run",
    "start": "node build.mjs && node dist/cli.js start",
    "prepublishOnly": "node build.mjs --publish",
    "postinstall": "node scripts/download-jre.js",
    "build:jre": "node scripts/build-jre-zip.js",
    "publish:all": "node scripts/publish-all.mjs"
  },
  "dependencies": {
    "esbuild": "^0.28.0",
    "ink": "^5.0.0",
    "marked": "^14.1.0",
    "react": "^18.3.1",
    "ws": "^8.18.0"
  },
  "files": [
    "dist/",
    "backend/"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
